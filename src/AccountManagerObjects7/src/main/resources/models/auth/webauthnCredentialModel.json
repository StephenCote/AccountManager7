{
	"name": "auth.webauthnCredential",
	"inherits": [
		"common.nameId",
		"common.directory"
	],
	"icon": "passkey",
	"label": "WebAuthn Credential",
	"description": "WebAuthn/FIDO2 credential for passwordless authentication. Stores the public key and metadata for a registered authenticator.",
	"constraints": {
		"field.credentialId": "credentialId, organizationId"
	},
	"fields": [
		{
			"name": "credentialId",
			"type": "string",
			"maxLength": 1024,
			"index": true
		},
		{
			"name": "publicKey",
			"type": "blob"
		},
		{
			"name": "publicKeyPem",
			"type": "string",
			"maxLength": 4096
		},
		{
			"name": "counter",
			"type": "long"
		},
		{
			"name": "rpId",
			"type": "string",
			"maxLength": 255
		},
		{
			"name": "origin",
			"type": "string",
			"maxLength": 1024
		},
		{
			"name": "algorithm",
			"type": "int"
		},
		{
			"name": "transports",
			"type": "list",
			"baseType": "string"
		},
		{
			"name": "lastUsed",
			"type": "timestamp"
		},
		{
			"name": "referenceType",
			"type": "string",
			"maxLength": 64
		},
		{
			"name": "referenceId",
			"type": "long"
		}
	]
}
