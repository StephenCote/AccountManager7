<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">
	<display-name>AccountManagerService</display-name>
	<module-name>AccountManagerService</module-name>
	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
	</welcome-file-list>
	<context-param>
		<param-name>log4jContextName</param-name>
		<param-value>AccountManagerService</param-value>
	</context-param>
	<context-param>
		<param-name>log4jConfiguration</param-name>
		<param-value>WEB-INF/resource/AccountManagerServiceLogging.xml</param-value>
	</context-param>
	<context-param>
		<param-name>amauthrole</param-name>
		<param-value>AccountUsers</param-value>
	</context-param>
	<context-param>
		<param-name>amrolemap</param-name>
		<param-value>WEB-INF/resource/roleMap.json</param-value>
	</context-param>
	<context-param>
		<param-name>logToConsole</param-name>
		<param-value>true</param-value>
	</context-param>
	<context-param>
		<param-name>isLog4jAutoInitializationDisabled</param-name>
		<param-value>false</param-value>
	</context-param>
	<context-param>
		<description>Database DataSource Name</description>
		<param-name>database.dsname</param-name>
		<param-value>comp/env/tomcat/datasources/postgresDS</param-value>
	</context-param>
	<context-param>
		<description>Database Check Schema</description>
		<param-name>database.checkSchema</param-name>
		<param-value>true</param-value>
	</context-param>
	<context-param>
		<description>Drop orphaned columns during schema check (off by default; flip deliberately to clean up removed fields)</description>
		<param-name>database.dropColumns</param-name>
		<param-value>false</param-value>
	</context-param>
	<context-param>
		<description>File Store Path (container-relative; IOFactory.DEFAULT_FILE_BASE)</description>
		<param-name>store.path</param-name>
		<param-value>${STORE_PATH}</param-value>
	</context-param>
	<context-param>
		<description>Stream Cutoff Size</description>
		<param-name>stream.cutoff</param-name>
		<param-value>5242880</param-value>
	</context-param>
	<context-param>
		<description>Data Generator Path (container-relative)</description>
		<param-name>datagen.path</param-name>
		<param-value>${DATAGEN_PATH}</param-value>
	</context-param>
	<context-param>
		<description>Vault Path (container-relative)</description>
		<param-name>vault.path</param-name>
		<param-value>${VAULT_PATH}</param-value>
	</context-param>
	<context-param>
		<description>Vault Credential Path (container-relative)</description>
		<param-name>vault.credential.path</param-name>
		<param-value>${VAULT_CREDENTIAL_PATH}</param-value>
	</context-param>
	<context-param>
		<description>Stable Diffusion Server</description>
		<param-name>sd.server</param-name>
		<param-value>${SD_SERVER}</param-value>
	</context-param>
		<context-param>
		<description>Stable Diffusion API Type</description>
		<param-name>sd.server.apiType</param-name>
		<param-value>SWARM</param-value>
	</context-param>
	<context-param>
		<description>Stable Diffusion Model</description>
		<param-name>sd.model</param-name>
		<param-value>juggernautXL_ragnarokBy.safetensors</param-value>
	</context-param>
	<context-param>
		<description>Stable Diffusion Refiner Model</description>
		<param-name>sd.refinerModel</param-name>
		<param-value>juggernautXL_ragnarokBy.safetensors</param-value>
	</context-param>
	<context-param>
		<description></description>
		<param-name>logToConsole</param-name>
		<param-value>true</param-value>
	</context-param>
	<context-param>
		<description>Poll for Remote Tasks</description>
		<param-name>task.poll.remote</param-name>
		<param-value>false</param-value>
	</context-param>
	<context-param>
		<description>Defer to Remote Tasks</description>
		<param-name>task.defer.remote</param-name>
		<param-value>false</param-value>
	</context-param>
		<context-param>
		<description>Face Server</description>
		<param-name>face.server</param-name>
		<param-value>${FACE_SERVER}</param-value>
	</context-param>
	<context-param>
		<description>Tag Server</description>
		<param-name>tag.server</param-name>
		<param-value>${TAG_SERVER}</param-value>
	</context-param>
	<context-param>
		<description>Voice Server TTS</description>
		<param-name>voice.tts.server</param-name>
		<param-value>${VOICE_TTS_SERVER}</param-value>
	</context-param>
	<context-param>
		<description>Voice Server STT</description>
		<param-name>voice.stt.server</param-name>
		<param-value>${VOICE_STT_SERVER}</param-value>
	</context-param>

	<context-param>
		<description>Voice Server Type</description>
		<param-name>voice.type</param-name>
		<param-value>local</param-value>
	</context-param>
		<context-param>
		<description>Voice Server Authorization Token</description>
		<param-name>voice.authorizationToken</param-name>
		<param-value></param-value>
	</context-param>
	<context-param>
		<description>Embedding Server</description>
		<param-name>embedding.server</param-name>
		<param-value>${EMBEDDING_SERVER}</param-value>
	</context-param>
	<context-param>
		<description>Embedding Server Type</description>
		<param-name>embedding.type</param-name>
		<param-value>local</param-value>
	</context-param>
		<context-param>
		<description>Embedding Server Authorization Token</description>
		<param-name>embedding.authorizationToken</param-name>
		<param-value></param-value>
	</context-param>
	<context-param>
		<description>Embedding vector dimensions requested from the embedding model (OPENAI branch). Must match the common.vectorExt.embedding column width (maxLength); a mismatch throws at startup. Leave blank to use the code default (768).</description>
		<param-name>embedding.dimensions</param-name>
		<param-value>768</param-value>
	</context-param>
	<context-param>
		<description>Vector DB support master switch. When false, the pgvector extension is disabled regardless of embedding-server health. When true (default), vector support stays enabled even if the embedding-server startup probe fails (a transient embedding outage no longer turns vector support off for the session).</description>
		<param-name>vector.enabled</param-name>
		<param-value>true</param-value>
	</context-param>
	<context-param>
		<description>Whether to probe the embedding server at startup (informational health check only — a failed probe is logged as a warning and does NOT disable vector support).</description>
		<param-name>vector.probe.embedding</param-name>
		<param-value>true</param-value>
	</context-param>
	<context-param>
		<description>Task Server</description>
		<param-name>task.server</param-name>
		<param-value>${TASK_SERVER}</param-value>
	</context-param>
	<context-param>
		<description>Task API Key</description>
		<param-name>task.api.key</param-name>
		<param-value>${TASK_API_KEY}</param-value>
	</context-param>
	<context-param>
		<description>Disable SSL Verification</description>
		<param-name>ssl.verification.disabled</param-name>
		<param-value>true</param-value>
	</context-param>
	<context-param>
		<description>Maximum Image Width</description>
		<param-name>image.maximum.width</param-name>
		<param-value>2048</param-value>
	</context-param>

	<context-param>
		<description>Maximum Image Height</description>
		<param-name>image.maximum.height</param-name>
		<param-value>2048</param-value>
	</context-param>
	<context-param>
         <param-name>org.apache.tomcat.websocket.textBufferSize</param-name>
         <param-value>65536</param-value>
    </context-param>
    <context-param>
            <param-name>org.apache.tomcat.websocket.binaryBufferSize</param-name>
            <param-value>65536</param-value>
	</context-param>
	<listener>
		<listener-class>org.cote.listeners.AccountManagerContextListener</listener-class>
	</listener>
	<filter>
		<filter-name>ExpiresFilter</filter-name>
		<filter-class>org.apache.catalina.filters.ExpiresFilter</filter-class>
		<init-param>
			<param-name>ExpiresByType image</param-name>
			<param-value>access plus 10 minutes</param-value>
		</init-param>
		<init-param>
			<param-name>ExpiresByType text/css</param-name>
			<param-value>access plus 10 minutes</param-value>
		</init-param>
		<init-param>
			<param-name>ExpiresByType application/javascript</param-name>
			<param-value>access plus 10 minutes</param-value>
		</init-param>
	</filter>

	<filter-mapping>
		<filter-name>ExpiresFilter</filter-name>
		<url-pattern>/*</url-pattern>
		<dispatcher>REQUEST</dispatcher>
	</filter-mapping>
	<filter>
		<filter-name>AuthNFilter</filter-name>
		<filter-class>org.cote.jaas.TokenFilter</filter-class>
		<init-param>
			<param-name>enabled</param-name>
			<param-value>True</param-value>
		</init-param>
	</filter>
	<filter-mapping>
		<filter-name>AuthNFilter</filter-name>
		<url-pattern>/rest/*</url-pattern>
		<url-pattern>/scim/*</url-pattern>
	</filter-mapping>
	<filter>
		<filter-name>CorsFilter</filter-name>
		<filter-class>org.apache.catalina.filters.CorsFilter</filter-class>
		<init-param>
			<param-name>cors.support.credentials</param-name>
			<param-value>true</param-value>
		</init-param>
		<init-param>
			<param-name>cors.allowed.methods</param-name>
			<param-value>GET,POST,HEAD,OPTIONS,PUT,DELETE,PATCH</param-value>
		</init-param>
		<init-param>
			<param-name>cors.allowed.origins</param-name>
			<param-value>${CORS_ALLOWED_ORIGINS}</param-value>
		</init-param>
		<init-param>
			<param-name>cors.allowed.headers</param-name>
			<param-value>Content-Type,X-Requested-With,Accept,Accept-Encoding,Accept-Language,Origin,Access-Control-Request-Method,Access-Control-Request-Headers,Connection,Host,authorization</param-value>
		</init-param>
		<init-param>
			<param-name>cors.exposed.headers</param-name>
			<param-value>Access-Control-Allow-Origin,Access-Control-Allow-Credentials</param-value>
		</init-param>
		<init-param>
			<param-name>cors.preflight.maxage</param-name>
			<param-value>10</param-value>
		</init-param>
	</filter>
	<filter-mapping>
		<filter-name>CorsFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>
	<servlet>
		<servlet-name>Jersey REST Service</servlet-name>
		<servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
		<init-param>
			<param-name>jakarta.ws.rs.Application</param-name>
			<param-value>org.cote.rest.config.RestServiceConfig</param-value>
		</init-param>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet>
		<display-name>MediaFormServlet</display-name>
		<servlet-name>MediaFormServlet</servlet-name>
		<servlet-class>org.cote.servlets.MediaFormServlet</servlet-class>
		<enabled>true</enabled>
		<async-supported>false</async-supported>
	</servlet>
	<servlet>
		<display-name>WebSocketService</display-name>
		<servlet-name>WebSocketService</servlet-name>
		<servlet-class>org.cote.sockets.WebSocketService</servlet-class>
		<enabled>true</enabled>
		<async-supported>true</async-supported>
	</servlet>
	<servlet>
		<display-name>MediaServlet</display-name>
		<servlet-name>MediaServlet</servlet-name>
		<servlet-class>org.cote.servlets.MediaServlet</servlet-class>
		<enabled>true</enabled>
		<async-supported>false</async-supported>
	</servlet>
	<servlet>
		<display-name>ArticleServlet</display-name>
		<servlet-name>ArticleServlet</servlet-name>
		<servlet-class>org.cote.servlets.ArticleServlet</servlet-class>
		<enabled>true</enabled>
		<async-supported>false</async-supported>
	</servlet>
	<servlet>
		<display-name>ThumbnailServlet</display-name>
		<servlet-name>ThumbnailServlet</servlet-name>
		<servlet-class>org.cote.servlets.ThumbnailServlet</servlet-class>
		<enabled>true</enabled>
		<async-supported>false</async-supported>
	</servlet>
	<servlet>
		<display-name>DWACServlet</display-name>
		<servlet-name>DWACServlet</servlet-name>
		<servlet-class>org.cote.servlets.DWACServlet</servlet-class>
		<enabled>true</enabled>
		<async-supported>false</async-supported>
	</servlet>
	<servlet-mapping>
		<servlet-name>MediaFormServlet</servlet-name>
		<url-pattern>/mediaForm</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>MediaServlet</servlet-name>
		<url-pattern>/media/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>ArticleServlet</servlet-name>
		<url-pattern>/article/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>ThumbnailServlet</servlet-name>
		<url-pattern>/thumbnail/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>DWACServlet</servlet-name>
		<url-pattern>/dwac/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>Jersey REST Service</servlet-name>
		<url-pattern>/rest/*</url-pattern>
		<url-pattern>/scim/*</url-pattern>
	</servlet-mapping>

	<resource-ref>
		<description>DB Connection Pooling</description>
		<res-ref-name>tomcat/datasources/postgresDS</res-ref-name>
		<res-type>javax.sql.DataSource</res-type>
		<res-auth>Container</res-auth>
	</resource-ref>

	<security-constraint>
		<web-resource-collection>
			<web-resource-name>Admin</web-resource-name>
			<url-pattern>/Protected/*</url-pattern>
		</web-resource-collection>
		<auth-constraint>
			<role-name>admin</role-name>
			<role-name>user</role-name>
		</auth-constraint>
	</security-constraint>

	<security-role>
		<role-name>admin</role-name>
	</security-role>
	<security-role>
		<role-name>user</role-name>
	</security-role>
	<login-config>
		<auth-method>FORM</auth-method>
		<realm-name>Default</realm-name>
		<form-login-config>
			<form-login-page>/login.html</form-login-page>
			<form-error-page>/loginError.html</form-error-page>
		</form-login-config>
	</login-config>

</web-app>
