{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mvn *)",
      "Bash(./gradlew *)",
      "Bash(gradle *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npx playwright *)",
      "Bash(pytest *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(cargo *)",
      "Bash(dotnet *)",
      "Bash(make *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/stop_verify.sh\"",
            "timeout": 1200,
            "statusMessage": "Running verification gate…"
          }
        ]
      }
    ]
  }
}
